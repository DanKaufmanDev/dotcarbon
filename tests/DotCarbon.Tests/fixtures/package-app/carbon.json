{
  "app": {
    "name": "Package Fixture",
    "version": "0.1.0",
    "identifier": "dev.dotcarbon.packagefixture"
  },
  "build": {
    "backendProject": "src-carbon/PackageApp.csproj",
    "frontendDist": "ui/dist",
    "buildCommand": "dotnet --info"
  },
  "bundle": {
    "targets": ["desktop"],
    "windows": {
      "webView2InstallMode": "skip"
    },
    "linux": {
      "formats": ["appimage", "deb", "rpm"]
    }
  }
}
