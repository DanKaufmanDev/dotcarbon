{
  "app": {
    "name": "Package Fixture",
    "version": "0.1.0",
    "identifier": "dev.dotcarbon.packagefixture"
  },
  "window": {
    "capabilities": [
      "main"
    ]
  },
  "security": {
    "enabled": true,
    "capabilities": {
      "main": {
        "windows": [
          "main"
        ],
        "commands": [
          "tray:*",
          "menu:*",
          "core:event_emit"
        ]
      }
    }
  },
  "build": {
    "backendProject": "src-carbon/PackageApp.csproj",
    "frontendDist": "ui/dist"
  },
  "bundle": {
    "targets": [
      "desktop"
    ],
    "windows": {
      "webView2InstallMode": "skip",
      "formats": ["msi", "nsis"]
    },
    "linux": {
      "formats": [
        "appimage",
        "deb",
        "rpm"
      ]
    }
  }
}
