<Project Sdk="Microsoft.NET.Sdk">

  <ItemGroup>
    <ProjectReference Include="..\DotCarbon.Core\DotCarbon.Core.csproj" />
    <InternalsVisibleTo Include="DotCarbon.Tests" />
  </ItemGroup>

  <ItemGroup>
    <!-- Windows DPAPI (ProtectedData). Only used on Windows; a no-op reference elsewhere. -->
