{
    "name": "@dotcarbon/create-app",
    "version": "0.1.1",
    "description": "Scaffold a new DotCarbon app",
    "type": "module",
    "bin": {
        "create-dotcarbon-app": "./dist/index.js"
    },
    "files": [
        "dist"
    ],
    "engines": {
        "node": ">=18"
    },
    "scripts": {
        "clean": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\"",
        "build": "npm run clean && tsc && node -e \"const fs=require('fs');fs.cpSync('templates','dist/templates',{recursive:true});fs.cpSync('shared','dist/shared',{recursive:true})\"",
        "dev": "tsc --watch",
        "prepublishOnly": "npm run build"
    },
    "devDependencies": {
        "@types/node": "^20.0.0",
        "typescript": "^5.0.0"
    },
    "author": "DanKaufmanDev",
    "license": "MIT",
    "homepage": "https://github.com/DanKaufmanDev/dotcarbon#readme",
    "bugs": {
        "url": "https://github.com/DanKaufmanDev/dotcarbon/issues"
    },
    "keywords": [
        "dotcarbon",
        "desktop",
        "scaffold",
        "create",
        "cli",
        "starter"
    ],
    "repository": {
        "type": "git",
        "url": "git+https://github.com/DanKaufmanDev/dotcarbon.git",
        "directory": "dotcarbon-js/packages/create-app"
    },
    "publishConfig": {
        "access": "public"
    }
}
