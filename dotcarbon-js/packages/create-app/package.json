{
    "name": "@dotcarbon/create-app",
    "version": "0.2.1",
    "description": "Scaffold a new DotCarbon app",
    "type": "module",
    "bin": {
        "create-dotcarbon-app": "./dist/index.js"
    },
    "files": [
        "dist"
    ],
    "engines": {
        "node": ">=18"
    },
    "scripts": {
        "clean": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\"",
        "build": "npm run clean && node scripts/gen-js.mjs && tsc && node -e \"const fs=require('fs');for(const d of ['templates','templates-js','shared'])fs.cpSync(d,'dist/'+d,{recursive:true})\"",
        "dev": "tsc --watch",
        "prepublishOnly": "npm run build"
    },
    "devDependencies": {
        "@types/node": "^20.0.0",
        "esbuild": "^0.28.1",
        "typescript": "^5.0.0"
    },
    "author": "DanKaufmanDev",
    "license": "MIT",
    "homepage": "https://github.com/DanKaufmanDev/dotcarbon#readme",
    "bugs": {
        "url": "https://github.com/DanKaufmanDev/dotcarbon/issues"
    },
    "keywords": [
        "dotcarbon",
        "desktop",
        "scaffold",
        "create",
        "cli",
        "starter"
    ],
    "repository": {
        "type": "git",
        "url": "git+https://github.com/DanKaufmanDev/dotcarbon.git",
        "directory": "dotcarbon-js/packages/create-app"
    },
    "publishConfig": {
        "access": "public"
    },
    "dependencies": {
        "@clack/prompts": "^1.7.0"
    }
}
