{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "$id": "https://dotcarbon.dev/schema/carbon.schema.json",
    "title": "Carbon config",
    "description": "Configuration for a DotCarbon desktop app (carbon.json).",
    "type": "object",
    "additionalProperties": false,
    "properties": {
        "$schema": { "type": "string", "description": "JSON Schema reference for editor autocomplete." },
        "app": { "$ref": "#/definitions/App" },
        "window": { "$ref": "#/definitions/Window" },
        "windows": {
            "type": "array",
            "items": { "$ref": "#/definitions/Window" },
            "default": [],
            "description": "Additional labeled windows/webviews created when the application starts."
        },
        "security": { "$ref": "#/definitions/Security" },
        "build": { "$ref": "#/definitions/Build" },
        "bundle": { "$ref": "#/definitions/Bundle" }
    },
    "definitions": {
        "App": {
            "type": "object",
            "additionalProperties": false,
            "description": "App identity.",
            "properties": {
                "name": { "type": "string", "description": "Human-readable product name.", "default": "Carbon App" },
                "version": { "type": "string", "description": "App version (semver).", "default": "0.1.0" },
                "identifier": {
                    "type": "string",
                    "description": "Reverse-DNS bundle identifier, e.g. \"com.example.app\". Used by installers, notifications, and OS integration.",
                    "default": "com.example.app"
                }
            }
        },
        "Window": {
            "type": "object",
            "additionalProperties": false,
            "description": "Main window options, applied at launch.",
            "properties": {
                "label": { "type": "string", "pattern": "^[A-Za-z0-9_-]+$", "default": "main", "description": "Unique application-wide window/webview label." },
                "url": { "type": ["string", "null"], "description": "Absolute URL or path relative to the embedded frontend root." },
                "parent": { "type": ["string", "null"], "description": "Optional label of the parent window." },
                "capabilities": {
                    "type": "array",
                    "items": { "type": "string" },
                    "default": [],
                    "description": "Named capability sets this window can use when security.enabled is true."
                },
                "title": { "type": "string", "default": "Carbon App" },
                "width": { "type": "integer", "minimum": 1, "default": 800 },
                "height": { "type": "integer", "minimum": 1, "default": 600 },
                "minWidth": { "type": ["integer", "null"], "minimum": 1, "description": "Minimum window width." },
                "minHeight": { "type": ["integer", "null"], "minimum": 1, "description": "Minimum window height." },
                "maxWidth": { "type": ["integer", "null"], "minimum": 1, "description": "Maximum window width." },
                "maxHeight": { "type": ["integer", "null"], "minimum": 1, "description": "Maximum window height." },
                "x": { "type": ["integer", "null"], "description": "Explicit top-left X. When x and y are both set, overrides center." },
                "y": { "type": ["integer", "null"], "description": "Explicit top-left Y. When x and y are both set, overrides center." },
                "center": { "type": "boolean", "default": true, "description": "Center the window on launch (ignored when x/y are set)." },
                "resizable": { "type": "boolean", "default": true },
                "fullscreen": { "type": "boolean", "default": false },
                "maximized": { "type": "boolean", "default": false },
                "alwaysOnTop": { "type": "boolean", "default": false },
                "decorations": { "type": "boolean", "default": true, "description": "Window chrome (title bar + border). Set false for a frameless window." },
                "transparent": { "type": "boolean", "default": false, "description": "Transparent window background." },
                "devtools": { "type": "boolean", "default": true, "description": "Allow opening the webview dev tools." },
                "contextMenu": { "type": "boolean", "default": true, "description": "Allow the webview's right-click context menu." },
                "icon": { "type": ["string", "null"], "description": "Path to a square PNG icon (1024x1024 recommended), relative to the project root. DotCarbon generates platform-specific icons from this source." }
            }
        },
        "Security": {
            "type": "object",
            "additionalProperties": false,
            "description": "Bridge command permissions for production apps.",
            "properties": {
                "enabled": { "type": "boolean", "default": false, "description": "When true, frontend command calls are denied unless allowed by a capability." },
                "devAllowAll": { "type": "boolean", "default": true, "description": "When true, development-server mode bypasses capability checks while production still enforces them." },
                "defaultCapabilities": {
                    "type": "array",
                    "items": { "type": "string" },
                    "default": [],
                    "description": "Capability names available to every window."
                },
                "capabilities": {
                    "type": "object",
                    "additionalProperties": { "$ref": "#/definitions/Capability" },
                    "default": {},
                    "description": "Inline named capability sets. Files under src-carbon/capabilities/*.json are also loaded, using the filename as the identifier when omitted."
                }
            }
        },
        "Capability": {
            "type": "object",
            "additionalProperties": false,
            "description": "A named allowlist of bridge commands for one or more windows.",
            "properties": {
                "identifier": { "type": ["string", "null"], "description": "Capability identifier. External files may omit this and use the filename." },
                "description": { "type": ["string", "null"] },
                "windows": {
                    "type": "array",
                    "items": { "type": "string" },
                    "default": [],
                    "description": "Window labels this capability applies to. Use * for all windows."
                },
                "commands": {
                    "type": "array",
                    "items": { "type": "string" },
                    "default": [],
                    "description": "Allowed command names. Supports exact names like app:greet, namespace wildcards like window:*, and *."
                },
                "permissions": {
                    "type": "array",
                    "items": { "type": "string" },
                    "default": [],
                    "description": "Alias for commands, useful for Tauri-style capability files."
                }
            }
        },
        "Build": {
            "type": "object",
            "additionalProperties": false,
            "description": "Dev-server and build wiring.",
            "properties": {
                "devCommand": { "type": "string", "description": "Command that starts your frontend dev server.", "default": "pnpm dev" },
                "buildCommand": { "type": ["string", "null"], "description": "Command that builds the frontend. When omitted, DotCarbon derives it from devCommand." },
                "devUrl": { "type": "string", "format": "uri", "description": "URL the dev server serves on.", "default": "http://localhost:5173" },
                "frontendDist": { "type": "string", "description": "Path to the built frontend, relative to the project.", "default": "ui/dist" },
                "backendProject": { "type": ["string", "null"], "description": "Path to the executable .csproj (or its directory), relative to the project. Recommended when a repository contains multiple executable projects." }
            }
        },
        "Bundle": {
            "type": "object",
            "additionalProperties": false,
            "description": "Platform packaging, native integration, signing, and update metadata.",
            "properties": {
                "publisher": { "type": ["string", "null"] },
                "copyright": { "type": ["string", "null"] },
                "category": { "type": "string", "default": "Utility" },
                "resources": { "type": "array", "items": { "type": "string" }, "default": [] },
                "fileAssociations": { "type": "array", "items": { "$ref": "#/definitions/FileAssociation" }, "default": [] },
                "protocols": { "type": "array", "items": { "$ref": "#/definitions/Protocol" }, "default": [] },
                "macOS": { "$ref": "#/definitions/MacOSBundle" },
                "windows": { "$ref": "#/definitions/WindowsBundle" },
                "linux": { "$ref": "#/definitions/LinuxBundle" },
                "updater": { "$ref": "#/definitions/UpdaterBundle" }
            }
        },
        "FileAssociation": {
            "type": "object",
            "additionalProperties": false,
            "required": ["name", "extensions"],
            "properties": {
                "name": { "type": "string" },
                "description": { "type": "string", "default": "" },
                "extensions": { "type": "array", "minItems": 1, "items": { "type": "string", "pattern": "^[A-Za-z0-9_-]+$" } },
                "mimeType": { "type": ["string", "null"] },
                "role": { "type": "string", "enum": ["Viewer", "Editor", "Shell", "None"], "default": "Editor" }
            }
        },
        "Protocol": {
            "type": "object",
            "additionalProperties": false,
            "required": ["name", "schemes"],
            "properties": {
                "name": { "type": "string" },
                "schemes": { "type": "array", "minItems": 1, "items": { "type": "string", "pattern": "^[A-Za-z][A-Za-z0-9+.-]*$" } }
            }
        },
        "MacOSBundle": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
                "minimumSystemVersion": { "type": "string", "default": "12.0" },
                "signingIdentity": { "type": ["string", "null"] },
                "entitlements": { "type": ["string", "null"] },
                "notarizationProfile": { "type": ["string", "null"], "description": "Keychain profile created with xcrun notarytool store-credentials." }
            }
        },
        "WindowsBundle": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
                "webView2InstallMode": { "type": "string", "enum": ["downloadBootstrapper", "offlineInstaller", "skip"], "default": "downloadBootstrapper" },
                "webView2InstallerPath": { "type": ["string", "null"], "description": "Path to the Evergreen standalone installer when webView2InstallMode is offlineInstaller." },
                "certificateThumbprint": { "type": ["string", "null"] },
                "timestampUrl": { "type": "string", "format": "uri", "default": "http://timestamp.digicert.com" }
            }
        },
        "LinuxBundle": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
                "category": { "type": "string", "default": "Utility" }
            }
        },
        "UpdaterBundle": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
                "active": { "type": "boolean", "default": false },
                "createArtifacts": { "type": "boolean", "default": false },
                "endpoints": { "type": "array", "items": { "type": "string" }, "default": [], "description": "Artifact URL templates supporting {{target}}, {{version}}, and {{artifact}}." },
                "publicKey": { "type": ["string", "null"] }
            }
        }
    }
}
